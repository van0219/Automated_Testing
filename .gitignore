__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Temporary files
Temp/
*.tmp
*.log

# Test outputs
*.json
*_analysis.json
*_images/
extracted_images/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Kiro specific
.kiro/cache/
.kiro/logs/

